# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-dev/
/out/

# production
/build

# misc
.DS_Store
*.pem
.vscode/
.idea/
*.code-workspace

# Claude Code local settings (machine-specific permissions)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist PWA
public/sw.js
public/sw.js.map
public/workbox-*.js
public/swe-worker-*.js

/lib/generated/prisma

# prisma — DB files + sidecars from rollback-journal mode (.db-journal) and
# WAL mode (.db-shm shared memory + .db-wal write-ahead log; created since
# MVP2 Phase E1 enabled `PRAGMA journal_mode = WAL` for the multi-writer
# web-tier + scheduler topology).
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-shm
/prisma/*.db-wal
*.db
*.db-journal
*.db-shm
*.db-wal
.restart-flag
