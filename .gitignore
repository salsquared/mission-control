# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-dev/
/out/

# production
/build

# misc
.DS_Store
*.pem
.vscode/
.idea/
*.code-workspace

# Claude Code local settings (machine-specific permissions)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# serwist PWA
public/sw.js
public/sw.js.map
public/workbox-*.js
public/swe-worker-*.js

/lib/generated/prisma

# prisma — DB files + sidecars from rollback-journal mode (.db-journal) and
# WAL mode (.db-shm shared memory + .db-wal write-ahead log; created since
# MVP2 Phase E1 enabled `PRAGMA journal_mode = WAL` for the multi-writer
# web-tier + scheduler topology).
/prisma/*.db
/prisma/*.db-journal
/prisma/*.db-shm
/prisma/*.db-wal
# Backup snapshots written by scripts/backup-db.sh and pre-migration
# rollback safety copies (e.g. prod.db.bak-pre-migrate-20260520-112849).
# The `*.db` glob above doesn't match these because the timestamp tail
# pushes the filename past the `.db` extension.
/prisma/*.db.bak*
*.db
*.db-journal
*.db-shm
*.db-wal
*.db.bak*
.restart-flag

# Generated resume artifacts (M8 Phase 2). The DB row points at the path;
# the bytes live here. Keep the directory tracked via .gitkeep so deployments
# don't fail on missing parent.
/data/resumes/*
!/data/resumes/.gitkeep

# Uploaded resume archive (S7.9 / M7.6.1). Append-only original-file bytes
# from /api/profile/import. ResumeUpload.artifactPath points at the file.
/data/resume-uploads/*
!/data/resume-uploads/.gitkeep

# perf-monitor JSONL + markdown summaries (scripts/perf-monitor.ts).
/data/perf/*
!/data/perf/.gitkeep

# Cross-tier LLM dedup cache (lib/ai/llm-cache.ts) + its WAL/shm sidecars. It's
# a content-addressed cache, not state — both tiers regenerate it. Also matched
# by the global *.db / *.db-wal / *.db-shm globs above; listed explicitly for
# clarity. See docs/cross-tier-llm-dedup.html.
/data/llm-cache.db
/data/llm-cache.db-wal
/data/llm-cache.db-shm

# Fetcher-health telemetry store (lib/fetcher-health/store.ts) + WAL/shm sidecars.
# Ephemeral per-tier fetch outcomes (48h retention), not state. Also matched by
# the global *.db globs above; listed explicitly for clarity. See
# docs/fetcher-health-store.html.
/data/fetcher-health.db
/data/fetcher-health.db-wal
/data/fetcher-health.db-shm

# Promptfoo eval output — JSON results + per-run dirs from `npm run test:prompts`.
# LOP-9. The fixtures themselves (eval/fixtures/, eval/suites/) ARE checked in;
# results are not.
/eval/output/
/eval/results.json
/eval/.promptfoo/
