# Tracked example of the untracked .env.production (OQ12b: .env* stays
# gitignored; this file documents the full prod-tier surface). Fresh machine:
#   cp .env.production.example .env.production
# Real secrets (Google OAuth, NextAuth, Gemini, …) live in the untracked .env.
DATABASE_URL="file:./prod.db"
PULSAR_URL="http://localhost:3103"
NEXTAUTH_URL="https://ms-prod.salsquared.xyz"

# SQLite-backed L2 cache so withCache entries survive PM2 restarts. Dev has
# this set in .env.development; prod was missing it, which meant every restart
# blew away the satellite/launches/etc. caches and hammered Celestrak — they'd
# then 403 us with "GP data has not updated since your last successful
# download" because dev (same outbound IP) had fetched within the window.
CACHE_BACKEND="sqlite"
# Real Gmail emission ON in production — drives application-side notifications
# (OFFER / REJECTION / INTERVIEW_SCHEDULED / ASSESSMENT_REQUESTED) into your inbox.
EMAIL_ENABLED=1
# Master app→Google-Calendar write switch, mirroring EMAIL_ENABLED.
GCAL_SYNC_ENABLED=1

# arXiv pacing — this is now the SINGLE SHARED rate across ALL processes (dev +
# prod + both schedulers), enforced by the Layer 3 cross-tier token bucket in
# data/arxiv-bucket.db (one paced line, not per-process). ~14/min stays under
# arXiv's "1 per 3s" soft policy (~20/min). If the shared file can't open, each
# process falls back to a per-process bucket at HALF this rate. NOTE: this value
# changed meaning from per-process (was 7) to shared — see
# docs/arxiv-rate-limit-fix.html Layer 3. Restart with --update-env to apply.
ARXIV_RATE_PER_MIN=14
# arXiv recovery cooldown (Layer 4) — after an observed 429 / "Rate exceeded",
# ALL arXiv calls stop for this long (cross-tier) so the IP block can clear,
# then one probe re-arms or recovers. 15 min default; far longer than any arXiv
# throttle window. See docs/arxiv-rate-limit-fix.html Layer 4.
ARXIV_COOLDOWN_MS=900000

# Gemini paid-tier (2026-05-20). Default in code is 12/min (free-tier safe);
# we're on paid tier so backfill / first-time scans aren't bottlenecked on the
# bucket. Sequential ingest can't usefully go above ~120 RPM anyway — Gemini's
# own response latency (~1-2 s/call) dominates past that. 60 is a 5× raise
# at negligible cost (~$0.0002/email × Flash-Lite pricing).
GEMINI_RATE_PER_MIN=60

PUBSUB_AUDIENCE=https://ms-prod.salsquared.xyz/api/gmail/webhook

# Lives in the untracked .env (shared across tiers), not here — gates Google
# sign-in to the listed addresses; unset = fail-open with a warning.
# ALLOWED_SIGNIN_EMAILS=<owner@example.com>
