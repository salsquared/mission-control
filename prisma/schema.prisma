// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CryptoPrice {
  id        String   @id @default(cuid())
  coinId    String   // e.g. "bitcoin"
  price     Float
  timestamp DateTime @default(now())

  @@index([coinId, timestamp])
}

model SavedPaper {
  id          String   @id @default(cuid())
  paperId     String   @unique
  title       String
  summary     String
  url         String
  authors     String
  publishedAt DateTime
  topic       String   // e.g. "AI", "Space"
  status      String   // e.g. "READ", "READ_LATER", "FAVORITE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, topic])
}

model SelectedHistoricalPaper {
  id        String   @id @default(cuid())
  paperId   String
  topic     String
  weekStart DateTime // Represents the week it was selected for

  @@unique([paperId, topic])
  @@index([topic, weekStart])
}

model SelectedReviewPaper {
  id        String   @id @default(cuid())
  paperId   String
  topic     String
  weekStart DateTime // Represents the week it was selected for

  @@unique([paperId, topic])
  @@index([topic, weekStart])
}

model GlobalSetting {
  id        String   @id @default("global")
  data      String   // JSON payload of settings
  updatedAt DateTime @updatedAt
}

// --- NextAuth Models --- //
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  applications  Application[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id           String    @id @default(cuid())
  userId       String
  company      String
  role         String?
  status       String
  nextSteps    String?
  dateApplied  DateTime?
  lastUpdateAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}


model Task {
  id          String    @id @default(cuid())
  text        String
  status      String    // "TODO", "IN_PROGRESS", "DONE"
  priority    String?   // "BLOCKER", "HIGH", "MEDIUM", "LOW"
  project     String?
  dueDate     DateTime?
  filePath    String
  lineNumber  Int
  notes       String?   // Markdown notes extracted under this task
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parentId    String?
  parent      Task?     @relation("TaskToTask", fields: [parentId], references: [id])
  children    Task[]    @relation("TaskToTask")

  @@index([status])
  @@index([filePath])
}

model LifeGoal {
  id        String   @id @default(cuid())
  text      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
