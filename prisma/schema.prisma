// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SavedPaper {
  id          String   @id @default(cuid())
  paperId     String   @unique
  title       String
  summary     String
  url         String
  authors     String
  publishedAt DateTime
  topic       String // e.g. "AI", "Space"
  status      String // e.g. "READ", "READ_LATER", "FAVORITE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, topic])
}

model SelectedHistoricalPaper {
  id        String   @id @default(cuid())
  paperId   String
  topic     String
  weekStart DateTime // Represents the week it was selected for

  // Cached paper metadata, persisted at pick time so re-rendering the weekly
  // pick costs zero arXiv/Semantic-Scholar calls (docs/archive/arxiv-rate-limit-fix.html
  // Layer 2). Nullable so pre-backfill rows migrate clean — a NULL title triggers
  // one legacy id_list fetch that then backfills the row. citationCount is
  // accepted-stale (OQ1): captured once, never refreshed.
  title         String?
  summary       String?
  url           String?
  author        String?
  publishedAt   DateTime?
  citationCount Int?

  @@unique([paperId, topic])
  @@index([topic, weekStart])
}

model SelectedReviewPaper {
  id        String   @id @default(cuid())
  paperId   String
  topic     String
  weekStart DateTime // Represents the week it was selected for

  // See SelectedHistoricalPaper — same cached-metadata rationale (Layer 2).
  title         String?
  summary       String?
  url           String?
  author        String?
  publishedAt   DateTime?
  citationCount Int?

  @@unique([paperId, topic])
  @@index([topic, weekStart])
}

model GlobalSetting {
  id                    String   @id @default("global")
  isDarkMode            Boolean  @default(true)
  viewHuesEnabled       Boolean  @default(true)
  viewHues              String   @default("{}") // JSON: Record<string, number>
  dashOrder             String   @default("[]") // JSON: string[]
  dashTitles            String   @default("{}") // JSON: Record<string, string>
  globalNegativeFilters String   @default("[]") // JSON: string[] — regex patterns merged into every watchlist's filter on read
  hiddenWatchlistIds    String   @default("[]") // JSON: string[] — watchlist IDs whose postings the user hid from the New/Side postings feed (synced cross-device)
  // Story S6.4 — quiet hours for email delivery. When both Start and End are
  // set, dispatchNotification strips "email" from the channels of any
  // dispatch that lands within the window (in-app surface stays unaffected).
  // Format "HH:MM" 24h; Timezone is an IANA name like "America/Los_Angeles".
  // NULL on either field disables quiet hours entirely.
  quietHoursStart       String?
  quietHoursEnd         String?
  quietHoursTimezone    String?
  version               Int      @default(0) // bumped on every write; client sends as If-Match
  updatedAt             DateTime @updatedAt
}

// --- NextAuth Models --- //
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  // PB-5 audit finding: persist the Gmail history.list watermark per user so
  // we can recover from a multi-day scheduler / webhook outage without losing
  // events. Gmail rejects `history.list?startHistoryId` older than ~7 days
  // with 404. The webhook updates this on each successful batch.
  lastSyncedHistoryId String?
  accounts            Account[]
  sessions            Session[]
  applications        Application[]
  gcalSyncState       GcalSyncState?
  profile             Profile?
  watchlists          Watchlist[]
  notifications       Notification[]
  generatedResumes    GeneratedResume[]
  blacklist           BlacklistedCompany[]
  profileSnapshots    ProfileSnapshot[]
  resumeUploads       ResumeUpload[]
  canons              Canon[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id                String    @id @default(cuid())
  userId            String
  company           String
  // PA-3 (PB-1/7 audit follow-up): the canonical key for dedup. Written by
  // ingest.ts via normalizeCompanyName(company) — same function used to look
  // up existing rows. Unique per-user via @@unique below so concurrent
  // webhook + manual "Scan inbox" can't both create duplicate rows for the
  // same employer (P2002 → caller falls through to update).
  //
  // NOT NULL since 2026-06-01 (migration require_application_normalized_company).
  // company is itself NOT NULL and normalizeCompanyName only returns "" for
  // empty input (which can't happen — every write path guards a non-empty
  // company), so a NULL here only ever meant "a create path bypassed the
  // normalize step" — exactly the track-as-application leak that silently
  // spawned duplicate Rocket Lab cards (the LOWER(company) key never matched
  // the indexed lookup). Making it NOT NULL turns that silent dedup-defeating
  // state into a loud insert failure at the offending call site instead of a
  // duplicate discovered weeks later. Every create goes through
  // createApplication (auto-derives) or sets it inline (track-as-application).
  normalizedCompany String
  // 2026-05-27 multi-role-per-company: distinguishes two applications at the
  // same company by role. Written via normalizeRoleName(role) at every create
  // call site. Folded into the unique key (see @@unique below) so two roles
  // at the same employer on the same kanban don't collide, while two emails
  // about the SAME role at the same employer still merge into one row. Null
  // for legacy rows until backfilled by scripts/backfill-normalized-role.ts.
  normalizedRole    String?
  // ATS-stable job identifier captured at track-as-application time from
  // posting.externalId (LinkedIn job ID, Greenhouse req ID, etc.). High-
  // precision dedup signal for "same job tracked via two ingress paths" —
  // checked AHEAD of company+role match in track-as-application's chain.
  // Null for Gmail-ingested rows (no posting linkage); future enhancement
  // could LLM-extract req IDs from email bodies.
  sourceJobId       String?
  // Layered-dedup fallback (CSULB drift, 2026-05-20). Registrable root of
  // the most recent sender's email domain (e.g. "csulb.edu"). NULL when
  // the sender was on a multi-tenant ATS / admissions platform (Greenhouse,
  // Lever, Common App, …) — those roots can't identify a single employer.
  // Written by ingest.ts via extractSenderDomain(fromHeader). Used as a
  // secondary lookup when normalizedCompany doesn't match (LLM drift across
  // emails from the same school/employer).
  senderDomain      String?
  role              String?
  // Job/role location (e.g. "Long Beach, CA" / "Remote"). Free-form display
  // string, nullable. Populated from JobPosting.location at track-as-application
  // time and editable inline from the detail sidebar; surfaced on the kanban
  // card so a tracked role's city is visible at a glance. No normalization /
  // dedup role — purely informational.
  location          String?
  status            String
  kind              String? // "job" | "internship" | "college" | "other" — null on legacy rows
  nextSteps         String?
  dateApplied       DateTime?
  lastEmailMsgId    String? // Gmail message id of the last ingested email; used to dedupe re-runs
  postingId         String?   @unique // links back to the JobPosting this app was tracked from, if any
  // Story S6.3 — "decision deadline approaching" nudges. NULL means unknown /
  // no deadline; the deadline-nudges scheduler job fires when within 3 days.
  decisionDeadline  DateTime?
  lastUpdateAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  events           ApplicationEvent[]
  posting          JobPosting?        @relation(fields: [postingId], references: [id], onDelete: SetNull)
  generatedResumes GeneratedResume[]
  contacts         Contact[]
  canon            Canon?             @relation(fields: [canonId], references: [id], onDelete: SetNull)

  // MB Phase 4 — "career" | "side". Career is the long-term professional
  // pipeline; side is gig / blue-collar / pay-the-bills work tracked separately
  // so the two kanbans don't pollute each other. No schema default: every
  // create site must pass track explicitly so a silent fallback can never
  // miscategorize a row (the previous @default("career") let ingest write
  // career rows without making the decision visible in code).
  track   String
  // §6 Q4 — which Canon this app is manually tagged to (manual tag only, nullable).
  canonId String?

  // 2026-05-27 multi-role-per-company: race-safe dedup now scoped by
  // normalizedRole as well, so two distinct roles at the same employer on
  // the same kanban don't collide. Two emails about the SAME role still
  // merge (same normalized triple). SQLite allows multiple NULLs in a unique
  // compound so legacy rows with normalizedRole=null stay unconstrained
  // until backfilled.
  @@unique([userId, normalizedCompany, normalizedRole, track])
  @@index([userId, status])
  @@index([userId, kind])
  @@index([userId, track])
  @@index([canonId])
  // Fallback dedup lookup (see senderDomain field comment).
  @@index([userId, senderDomain])
  // 2026-05-27 multi-role-per-company: high-precision dedup hint when
  // promoting a posting to an application — looked up before company+role
  // match in track-as-application.
  @@index([userId, sourceJobId])
}

// Story S11.2 — per-application recruiter / hiring-manager contacts. Optional
// per row: not every application has a known contact (cold portal applies,
// generic careers@ inbox, etc.). Cascades on Application delete so orphan
// contacts can't accumulate. The stale-application nudge job consults the
// most-recent contact (by lastTouchedAt, fallback to position) to address
// the "draft a follow-up" suggestion to a person by name.
model Contact {
  id            String    @id @default(cuid())
  applicationId String
  name          String
  email         String?
  role          String? // free-form: "Recruiter", "Hiring Manager", "Referrer", …
  notes         String?
  lastTouchedAt DateTime?
  position      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, position])
}

model ApplicationEvent {
  id            String    @id @default(cuid())
  applicationId String
  // APPLIED | STATUS_CHANGED | EMAIL_RECEIVED | ASSESSMENT_REQUESTED | INTERVIEW_SCHEDULED | OFFER | REJECTION | NOTE
  kind          String
  title         String
  occurredAt    DateTime // when it happened in real life
  scheduledAt   DateTime? // future-dated for INTERVIEW_SCHEDULED / ASSESSMENT_REQUESTED
  endsAt        DateTime?
  fromStatus    String?
  toStatus      String?
  notes         String?
  emailMsgId    String? // gmail msg id this event came from
  gcalEventId   String? // populated after MS→Gcal sync
  gcalUpdatedAt DateTime? // Gcal `updated` field at last sync; for last-write-wins
  syncSource    String? // "ms" | "gcal" — which side originated the last write
  // PB-5: per-event side-effect checkpoints. NULL = the side-effect has not
  // completed for this event. Ingest re-fires side-effects on retry only for
  // events whose checkpoint is still null. Decouples the "did we see this
  // message?" gate (Application.lastEmailMsgId) from the "did the side-effects
  // commit?" gate, closing the crash-recovery hole.
  notifiedAt    DateTime?
  gcalSyncedAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Dedupe re-ingestion of the same email producing the same kind of event
  @@unique([applicationId, emailMsgId, kind])
  @@index([applicationId, occurredAt])
  @@index([scheduledAt])
  @@index([gcalEventId])
}

model GcalSyncState {
  userId       String   @id
  syncToken    String?
  lastSyncedAt DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Profile spine (§7 milestone, decision 4 — Option C: hybrid spine + JSON bullets).
// Bullets live as JSON arrays on the owning row, shape:
//   [{ id: cuid, text: string, tags: string[], locked: boolean, excluded: boolean }]
model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  headline  String?
  // M7.9.1 (story S7.14) — one-sentence professional tagline rendered as
  // a subtitle under the H1 on every generated resume. Distinct from
  // `headline` (which is the user's name, displayed as the resume H1
  // per the M8.4 canonical-naming work). Capped at 200 chars at the
  // zod schema layer; the column itself is unbounded TEXT. Optional —
  // null means no subtitle line on the resume.
  //
  // Story S7.14 follow-up (2026-05-26): the legacy `summary` column was
  // dropped (`drop_profile_summary` migration) — tagline replaces it as
  // the only one-line pitch. Existing summary content was discarded in
  // the migration.
  tagline   String?
  location  String?
  email     String?
  phone     String?
  links     String? // JSON: [{label, url}]
  skills    String? // JSON: [{category, items: string[]}]
  hobbies   String? // JSON: string[]
  languages String? // JSON: [{name, proficiency}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workRoles WorkRole[]
  projects  Project[]
  education Education[]
}

model WorkRole {
  id          String    @id @default(cuid())
  profileId   String
  company     String
  title       String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  bullets     String    @default("[]")
  // M7.8.1 (story S7.13) — free-form per-entity notes the user writes in
  // their own voice. Voice + experience grounding for the LLM bullet-assist
  // paths (M7.6) and resume-gen synthesis (M8.6). Never rendered verbatim
  // into a resume. Capped at 8 KB at the schema layer (lib/schemas/profile.ts)
  // to bound prompt budgets.
  scratchpad  String?
  // Posting-category-conditional pin. JSON array of keyword strings. When a
  // resume is generated against a posting whose extracted keywords contain
  // any of these (case-insensitive whole-word match — same matcher as
  // lib/resumes/select.ts), this entity is forced into the selection,
  // marked unremovable by the one-page pruner, and moved to position 0 of
  // its section regardless of score-based / LLM-suggested ordering. Empty
  // array (or null) means no conditional pin. Stored as JSON-stringified
  // array, same pattern as `bullets`.
  pinKeywords String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, position])
}

model Project {
  id          String   @id @default(cuid())
  profileId   String
  name        String
  description String?
  repoUrl     String?
  liveUrl     String?
  // Nullable (mirrors Education, not WorkRole's required startDate) so the
  // additive migration over existing date-less project rows needs no backfill.
  // Render rule (lib/resumes/templates/ats-plain.tsx): startDate present +
  // endDate null ⇒ "<start> – Present"; startDate null ⇒ no date emitted.
  startDate   DateTime?
  endDate     DateTime?
  bullets     String   @default("[]")
  // M7.8.1 (story S7.13) — see WorkRole.scratchpad. Per-project user-voice
  // notes; consumed by bullet-assist + resume-gen synthesis.
  scratchpad  String?
  // See WorkRole.pinKeywords — same semantic.
  pinKeywords String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, position])
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  institution String
  degree      String?
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  bullets     String    @default("[]")
  // M7.8.1 (story S7.13) — see WorkRole.scratchpad. Per-education user-voice
  // notes; consumed by bullet-assist + resume-gen synthesis.
  scratchpad  String?
  // See WorkRole.pinKeywords — same semantic.
  pinKeywords String?
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, position])
}

// Story S7.6 — versioned snapshots of a user's Profile. Button-press only —
// no auto-snapshotting on every profile edit (would balloon row count and
// add a hidden write path the user can't see). The payload is the full
// HydratedProfile (Profile + workRoles + projects + education with parsed
// bullets) serialized to JSON; rollback UX is intentionally deferred.
// First deliverable is just a read-only safety net so the user can see
// how their profile looked at past points in time.
model ProfileSnapshot {
  id        String   @id @default(cuid())
  userId    String
  takenAt   DateTime @default(now())
  label     String? // optional free-form label set by the user at capture time
  payload   String // JSON: serialized HydratedProfile
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
}

// Story S7.9 — append-only archive of raw uploaded resume files. Today's M7.4
// import path extracts text, runs the LLM to parse it into structured form,
// merges into the canonical Profile, then discards both the raw text and the
// intermediate extraction. That discard is lossy — wording variants and
// details that lose the dedup race vanish forever. This table closes the
// discard: every file in every /api/profile/import call writes one
// ResumeUpload row capturing the raw text, the LLM's structured output, and
// (when feasible) the original bytes on disk. Future LLM-driven features
// (bullet-assist S7.7/S7.8, tailored generation, anything else) can reach
// back into prior versions to surface alternative framings or recover
// details the merge dropped. Append-only: uploading a new resume never
// deletes prior rows; pre-S7.9 uploads are not backfilled.
//
// rawText capped at 200 KB in code (matches the M7.4 import-pipeline ceiling).
// parsedJson stores the canonical LLM extraction shape so the same structured
// form is available to future consumers without re-running the LLM.
// artifactPath mirrors GeneratedResume.artifactPath — relative path under
// data/resume-uploads/ (gitignored). Null when bytes weren't persisted (e.g.
// JSON-paste imports with no original binary).
// importBatchId groups multi-file uploads from a single import call so a
// UI can later show "the three resumes I uploaded together on date X".
model ResumeUpload {
  id            String   @id @default(cuid())
  userId        String
  filename      String // original upload filename, as supplied by the client
  mimeType      String // application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document, text/plain, application/json, ...
  sizeBytes     Int
  rawText       String // post-extract plaintext, capped at 200 KB in code
  parsedJson    String // JSON: the LLM extraction output that fed the merge
  artifactPath  String? // relative path under data/resume-uploads/ (gitignored). Null when the upload was JSON-paste or bytes couldn't be written.
  importBatchId String? // groups multi-file uploads from one /api/profile/import call
  uploadedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, uploadedAt])
}

model Task {
  id        String    @id @default(cuid())
  text      String
  status    String // "TODO", "IN_PROGRESS", "DONE"
  priority  String? // "BLOCKER", "HIGH", "MEDIUM", "LOW"
  project   String?
  dueDate   DateTime?
  position  Int       @default(0)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  parentId String?
  parent   Task?   @relation("TaskToTask", fields: [parentId], references: [id])
  children Task[]  @relation("TaskToTask")

  @@index([status])
  @@index([position])
}

model LifeGoal {
  id            String   @id @default(cuid())
  text          String
  estimatedTime String?
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CacheEntry {
  key       String   @id
  data      String // JSON-serialized response body
  expiry    DateTime
  updatedAt DateTime @updatedAt

  @@index([expiry])
}

// MB Phase 1 — job discovery. See docs/implementation.md §MB.1.
model Watchlist {
  id               String    @id @default(cuid())
  userId           String
  name             String
  kind             String // "careers-page" | "greenhouse" | "lever" | "ashby" | "workday" | "linkedin"
  config           String // JSON: per-kind config (see lib/schemas/watchlists.ts discriminated union)
  // PB-14: when set, the row was created from a COMPANY_DIRECTORY entry whose
  // `name` matches this value. Reads hydrate `config` from the live directory
  // entry at fetch time, so slug corrections to lib/company-directory.ts
  // propagate automatically. NULL = legacy / Advanced-tab row → `config` is
  // the source of truth.
  directoryKey     String?
  // JSON array of regex patterns. Postings whose (title + snippet + location)
  // matches any pattern are hidden from the bell / new-postings feed at GET
  // time. Invalid regexes are silently skipped. NULL = no filtering.
  negativeFilters  String?
  // Story S6.2 — per-watchlist notification preference:
  //   "each"   — fire one bell notification per new posting (current default)
  //   "digest" — suppress per-posting; posting-digest scheduler job rolls them
  //              up into one daily summary and updates lastDigestAt
  //   "silent" — never notify; postings still appear in the discovery feed
  notificationMode String    @default("each")
  lastDigestAt     DateTime?
  scheduleMinutes  Int       @default(30)
  lastRunAt        DateTime?
  lastSuccessAt    DateTime?
  lastError        String?
  active           Boolean   @default(true)
  // MB Phase 4 — "career" | "side". Career = long-term professional ATSes
  // (Greenhouse, Lever, Workday, etc.); side = gig / blue-collar keyword
  // watchlists (typically LinkedIn search by job-type keywords). Scheduler
  // crawls both transparently; UI segregates them.
  track            String    @default("career")
  // §6 Q4 — optional manual link: a role-watchlist feeds a canon; its jobs inherit.
  canonId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postings JobPosting[]
  canon    Canon?       @relation(fields: [canonId], references: [id], onDelete: SetNull)

  @@index([userId, active])
  @@index([userId, track, active])
  @@index([canonId])
}

model JobPosting {
  id                   String    @id @default(cuid())
  watchlistId          String
  externalId           String // sha256(company + '|' + title + '|' + sourceUrl)
  company              String
  title                String
  location             String?
  postedAt             DateTime?
  snippet              String?
  sourceUrl            String
  // PB-15: normalized employment type for the new-postings filter UI.
  // One of "full-time" | "part-time" | "internship" | "contract" | "temporary"
  // or NULL when neither the ATS payload nor the title gave a clear signal.
  // Populated by fetchers via lib/fetchers/employment-type.ts.
  employmentType       String?
  // Story S5.9 — compensation parsed out of postings. Stored as integer
  // minor units (e.g. dollars; not cents — most postings quote whole-dollar
  // ranges) so the UI can sort. NULL when no recognisable range was found.
  // compensationCadence is one of "hour" | "day" | "week" | "month" | "year"
  // | NULL; the UI defaults to "year" when the cadence is null but a range
  // is present (the dominant case for white-collar postings). Currency
  // defaults to "USD" — we have no postings outside the US yet; when we do,
  // the parser will infer from the symbol and this column carries the
  // ISO-4217 code.
  compensationMin      Int?
  compensationMax      Int?
  compensationCurrency String?
  compensationCadence  String?
  status               String // "new" | "tracked" | "hidden" | "closed"
  firstSeenAt          DateTime  @default(now())
  lastSeenAt           DateTime  @default(now())
  removedAt            DateTime?
  raw                  String // JSON of the raw extracted fields, for debugging

  watchlist   Watchlist    @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  application Application? // back-relation; the foreign key lives on Application

  @@unique([watchlistId, externalId])
  @@index([status, lastSeenAt])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  kind        String // "posting" | "application" | "system"
  // tier: "critical" | "standard" | "low". Drives default channels and UI
  // prominence. Central dispatcher (lib/notifications/dispatch.ts) sets this.
  tier        String    @default("low")
  title       String
  body        String?
  payload     String // JSON: { postingId? / applicationId? / ... }
  channels    String    @default("in_app") // comma-sep: "in_app", "in_app,email", ...
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  dismissedAt DateTime?
  // Email delivery (Gmail OAuth, OQ1 — see docs/implementation.md). NULL means
  // either no email was attempted (channels excluded "email") or it hasn't
  // dispatched yet. emailError is set when delivery was attempted but failed.
  emailSentAt DateTime?
  emailError  String?
  // PB-8: dedup key for at-most-once delivery semantics. Caller-supplied,
  // typically `${kind}:${targetId}:${type}:${YYYY-MM-DD-UTC}`. Concurrent
  // dispatches with the same key race on the @unique constraint — the loser
  // catches P2002 and no-ops, eliminating the cooldown-SELECT-then-INSERT
  // race in stale-applications / deadline-nudges / posting-digest. Nullable
  // so the in-app `/api/notifications/test` and legacy callers stay
  // unaffected (SQLite allows multiple NULLs in a unique column).
  dedupKey    String?   @unique
  // Fix A (circuit breaker — docs/postmortem-self-notification-mail-loop.html §11).
  // Generic per-feature rate-limit grouping label in the form "<feature>:<id>"
  // (e.g. "application:<applicationId>"), written by dispatchNotification from
  // the feature registry (lib/notifications/circuit-breaker.ts). DISTINCT from
  // dedupKey: dedupKey is @unique = at-most-once-ever; scopeKey is non-unique
  // and indexed so the breaker can count recent emailed notifications within a
  // feature's scope. NULL when the dispatch's feature isn't registered (or has
  // no scope id in its payload).
  scopeKey       String?
  // Fix C (store undo handles — same postmortem §11). The Gmail messageId of
  // the sent notification email, persisted on the success path of
  // dispatchNotificationEmail so a future cleanup can map a notification back
  // to the inbox message it produced. NULL when no email was sent (in-app-only
  // tier, EMAIL_ENABLED muted, breaker-suppressed, or a failed send).
  emailMessageId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  // Fix A: the breaker's per-feature count is `WHERE userId = ? AND scopeKey = ?
  // AND createdAt >= ?` — this index makes it an exact-prefix lookup.
  @@index([userId, scopeKey, createdAt])
}

// PB-6: Pub/Sub at-least-once dedup. Each Gmail webhook envelope carries a
// unique `messageId`; we INSERT OR IGNORE on it before any side-effect work
// so a redelivered envelope no-ops in O(1). Pruned on a daily cadence — Pub/
// Sub doesn't reuse messageIds, so anything > 30 days old is safe to drop.
model WebhookDelivery {
  messageId  String   @id
  source     String // "gmail" — leave room for future webhooks
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

// M8 Phase 2 — resume archival + traceability. See docs/implementation.md §M8-2.1.
model GeneratedResume {
  id              String   @id @default(cuid())
  userId          String
  applicationId   String?
  createdAt       DateTime @default(now())
  postingInput    String // JSON: { url?, text?, parsedKeywords[] }
  // M8.4.1 (story S8.11) — hydrated at gen time from parsedPosting. Drives the
  // global "Previous resumes" dropdown on GenerateResumeCard so users can see
  // company/title at a glance. NULL on legacy rows generated before the columns
  // existed; dropdown shows "(unknown)" for those.
  postingTitle    String?
  postingCompany  String?
  // One-sentence posting-tailored tagline rendered as the subtitle under
  // the resume's H1. LLM-generated at gen time (callsite `resume-tagline`),
  // grounded on profile + parsed posting, so the security-guard resume gets
  // a posting-relevant pitch even though the user's profile.tagline is
  // tech-coded. NULL on legacy rows pre-dating this column; the template
  // falls back to profile.tagline in that case.
  tagline         String?
  profileSnapshot String // JSON: full hydrated profile at gen-time
  selections      String // JSON: [{ kind, sourceId, sourceLabel, bulletId, originalText, rewrittenText, score, matchedTags[], matchedKeywords[], locked }]
  // Story S8.8 — JSON array of posting keywords that have NO coverage in the
  // profile (no bullet tags match, no bullet text contains them as a substring).
  // NULL on legacy rows generated before the column existed.
  skillsGap       String?
  templateKey     String   @default("ats-plain")
  format          String // "pdf" | "docx"
  status          String // "ready" | "failed"
  artifactPath    String? // relative path under data/resumes/ (gitignored)
  error           String?
  // Canon linkage (§6). canonId is set on canon-generated + specialized resumes.
  // isCanonical=true marks a canon VERSION (canonVersion auto-increments per
  // canon, newest = current); a specialization pass writes isCanonical=false +
  // applicationId so it's a per-job child, not a version.
  canonId         String?
  isCanonical     Boolean  @default(false)
  canonVersion    Int?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  canon       Canon?       @relation(fields: [canonId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([applicationId])
  @@index([canonId, canonVersion])
}

// User-curated company blacklist. Names entered here are filtered out of every
// recommendation surface (Watch-company directory results, Discover Gemini
// suggestions, auto-discover panel) so a company can never be re-suggested
// once the user has explicitly opted out (e.g. "no Thiel companies", "no
// defense"). Match key is `normalizedName` — `normalizeCompanyName` output,
// lowercased — so "Acme" and "Acme, Inc." collapse to one entry. Display key
// is `name` (what the user actually typed).
model BlacklistedCompany {
  id             String   @id @default(cuid())
  userId         String
  name           String // What the user typed — shown back in the editor.
  normalizedName String // normalizeCompanyName(name) — comparison key.
  reason         String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId])
}

// Canonical resumes ("Canons") — docs/archive/canonical-resumes.html. A Canon is a
// named role-archetype that owns one reusable resume (a curated subset of the
// master profile). Generation feeds the canon's keyword text to the unchanged
// resume pipeline; jobs are manually tagged to a canon and reuse its artifact.
model Canon {
  id          String  @id @default(cuid())
  userId      String
  name        String // user-facing label, e.g. "Security Officer"
  slug        String // normalizeRoleName(name) — match/dedup key
  track       String // "career" | "side" — every canon nests under one track
  description String?

  // Raw user-provided keyword text (NOT JSON). Side = the feeding watchlist's
  // keyword string; career = typed by the user. Split into a flat term array
  // at gen time; no weights in v1 (§6 Q3/Q6).
  keywords String @default("")

  // Render default = PDF + one-page (§6 Q9). pinnedEntityIds/sectionOrder are
  // DEFERRED (§6 Q8) — left null; the pipeline + resume-tagline order the resume.
  onePage         Boolean @default(true)
  pinnedEntityIds String?
  sectionOrder    String?

  // currentResumeId points at the active (latest) canon GeneratedResume version
  // (plain id, not a relation, to avoid a second Canon<->GeneratedResume edge).
  currentResumeId String?

  // Demand-driven, entity-scoped staleness (§6 Q7). resumeStale flips true only
  // when an entity in resumeEntityIds changes, or the canon's keywords change.
  resumeStale     Boolean @default(true)
  resumeEntityIds String? // JSON string[] — the staleness dependency set

  // Manual builder selection (docs/resume-manual-builder.html). JSON shape:
  // { version, sectionOrder, sectionsOff[], entities:{<id>:{kind,bulletIds[]}}, excluded[], extras }.
  // When set, POST /api/resumes resolves THIS instead of running the auto-pipeline
  // (manual-only canon generation — OQ15). Null = not yet curated.
  selection String?

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes      GeneratedResume[]
  applications Application[]
  watchlists   Watchlist[]

  @@unique([userId, slug])
  @@index([userId, track, active])
}
