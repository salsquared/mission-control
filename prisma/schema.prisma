// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SavedPaper {
  id          String   @id @default(cuid())
  paperId     String   @unique
  title       String
  summary     String
  url         String
  authors     String
  publishedAt DateTime
  topic       String   // e.g. "AI", "Space"
  status      String   // e.g. "READ", "READ_LATER", "FAVORITE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, topic])
}

model SelectedHistoricalPaper {
  id        String   @id @default(cuid())
  paperId   String
  topic     String
  weekStart DateTime // Represents the week it was selected for

  @@unique([paperId, topic])
  @@index([topic, weekStart])
}

model SelectedReviewPaper {
  id        String   @id @default(cuid())
  paperId   String
  topic     String
  weekStart DateTime // Represents the week it was selected for

  @@unique([paperId, topic])
  @@index([topic, weekStart])
}

model GlobalSetting {
  id              String   @id @default("global")
  isDarkMode      Boolean  @default(true)
  viewHuesEnabled Boolean  @default(true)
  viewHues        String   @default("{}")  // JSON: Record<string, number>
  dashOrder       String   @default("[]") // JSON: string[]
  dashTitles      String   @default("{}") // JSON: Record<string, string>
  version         Int      @default(0)   // bumped on every write; client sends as If-Match
  updatedAt       DateTime @updatedAt
}

// --- NextAuth Models --- //
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  gcalSyncState GcalSyncState?
  profile       Profile?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Application {
  id              String    @id @default(cuid())
  userId          String
  company         String
  role            String?
  status          String
  kind            String?   // "job" | "internship" | "college" | "other" — null on legacy rows
  nextSteps       String?
  dateApplied     DateTime?
  lastEmailMsgId  String?   // Gmail message id of the last ingested email; used to dedupe re-runs
  lastUpdateAt    DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          ApplicationEvent[]

  @@index([userId, status])
  @@index([userId, kind])
}

model ApplicationEvent {
  id             String    @id @default(cuid())
  applicationId  String
  // APPLIED | STATUS_CHANGED | EMAIL_RECEIVED | ASSESSMENT_REQUESTED | INTERVIEW_SCHEDULED | OFFER | REJECTION | NOTE
  kind           String
  title          String
  occurredAt     DateTime  // when it happened in real life
  scheduledAt    DateTime? // future-dated for INTERVIEW_SCHEDULED / ASSESSMENT_REQUESTED
  endsAt         DateTime?
  fromStatus     String?
  toStatus       String?
  notes          String?
  emailMsgId     String?   // gmail msg id this event came from
  gcalEventId    String?   // populated after MS→Gcal sync
  gcalUpdatedAt  DateTime? // Gcal `updated` field at last sync; for last-write-wins
  syncSource     String?   // "ms" | "gcal" — which side originated the last write
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, occurredAt])
  @@index([scheduledAt])
  @@index([gcalEventId])
  // Dedupe re-ingestion of the same email producing the same kind of event
  @@unique([applicationId, emailMsgId, kind])
}

model GcalSyncState {
  userId       String   @id
  syncToken    String?
  lastSyncedAt DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Profile spine (§7 milestone, decision 4 — Option C: hybrid spine + JSON bullets).
// Bullets live as JSON arrays on the owning row, shape:
//   [{ id: cuid, text: string, tags: string[], locked: boolean, excluded: boolean }]
model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  headline  String?
  summary   String?
  location  String?
  email     String?
  phone     String?
  links     String?  // JSON: [{label, url}]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workRoles WorkRole[]
  projects  Project[]
  education Education[]
}

model WorkRole {
  id        String    @id @default(cuid())
  profileId String
  company   String
  title     String
  location  String?
  startDate DateTime
  endDate   DateTime?
  bullets   String    @default("[]")
  position  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, position])
}

model Project {
  id          String   @id @default(cuid())
  profileId   String
  name        String
  description String?
  repoUrl     String?
  liveUrl     String?
  bullets     String   @default("[]")
  metrics     String?  // JSON: populated by §9 GitHub scheduler job
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, position])
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  institution String
  degree      String?
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  bullets     String    @default("[]")
  position    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, position])
}


model Task {
  id          String    @id @default(cuid())
  text        String
  status      String    // "TODO", "IN_PROGRESS", "DONE"
  priority    String?   // "BLOCKER", "HIGH", "MEDIUM", "LOW"
  project     String?
  dueDate     DateTime?
  position    Int       @default(0)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parentId    String?
  parent      Task?     @relation("TaskToTask", fields: [parentId], references: [id])
  children    Task[]    @relation("TaskToTask")

  @@index([status])
  @@index([position])
}

model LifeGoal {
  id            String   @id @default(cuid())
  text          String
  estimatedTime String?
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CacheEntry {
  key       String   @id
  data      String   // JSON-serialized response body
  expiry    DateTime
  updatedAt DateTime @updatedAt

  @@index([expiry])
}
